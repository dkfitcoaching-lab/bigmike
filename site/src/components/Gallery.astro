---
/*
  Gallery section — competition and gym photos.
  Alt text uses verified show names/dates where known.
*/

const photos = [
  { src: '/img/gallery-champion-2024.jpg', alt: 'Big Mike Ely — 2024 IFBB Pro Masters World Champion', label: '2024 Masters World Champion' },
  { src: '/img/gallery-most-muscular-stage.jpg', alt: 'Big Mike Ely — Most muscular on stage, 2014', label: 'Most Muscular' },
  { src: '/img/gallery-back-dbl-bicep.jpg', alt: 'Big Mike Ely — Back double bicep, Muscular Development 2013', label: 'Muscular Development 2013' },
  { src: '/img/gallery-side-chest-stage.jpg', alt: 'Big Mike Ely — Side chest, Muscular Development 2013', label: 'Side Chest' },
  { src: '/img/gallery-wings-chicago-2015.jpg', alt: 'Big Mike Ely — Wings of Strength Chicago Pro 2015', label: 'Wings of Strength 2015' },
  { src: '/img/gallery-most-muscular-crab.jpg', alt: 'Big Mike Ely — Most muscular crab pose on stage', label: 'Most Muscular' },
  { src: '/img/about-back-gym.jpg', alt: 'Big Mike Ely — Rear lat spread, gym, Masters Olympia prep 2023', label: 'Olympia Prep 2023' },
  { src: '/img/gallery-gym-side-tricep.jpg', alt: 'Big Mike Ely — Side tricep in gym', label: 'Side Tricep' },
  { src: '/img/gallery-wings-stage.jpg', alt: 'Big Mike Ely — Back double bicep on stage', label: 'Stage Pose' },
  { src: '/img/gallery-ferrigno-prep.jpg', alt: 'Big Mike Ely — Ferrigno Legacy Pro prep 2015', label: 'Ferrigno Legacy Prep' },
  { src: '/img/about-tom-platz.jpg', alt: 'Big Mike Ely with Tom Platz, Pittsburgh 2022', label: 'With Tom Platz' },
  { src: '/img/about-hany-rambod.jpg', alt: 'Big Mike Ely with Hany Rambod backstage, 2014', label: 'With Hany Rambod' },
];
---

<section class="section-pad" id="gallery" style="background:linear-gradient(180deg,var(--bg),rgba(8,8,6,1),var(--bg))">
  <div class="section-title">Gallery</div>
  <div class="gallery-grid">
    {photos.map((p, i) => (
      <div class={`gallery-item ${i === 0 ? 'gallery-featured' : ''}`}>
        <img src={p.src} alt={p.alt} loading="lazy" />
        <div class="gallery-label">{p.label}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 12px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .gallery-featured {
    grid-column: span 2;
    grid-row: span 2;
  }

  .gallery-item {
    border-radius: 14px;
    overflow: hidden;
    border: 1.5px solid var(--borderS);
    transition: border-color .3s, transform .3s, box-shadow .3s;
    position: relative;
    contain: layout style paint;
  }
  .gallery-item:hover {
    border-color: var(--accB);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px var(--accS), 0 0 0 1px var(--accGlow);
  }
  .gallery-item img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    filter: contrast(1.05) brightness(.95);
    transition: transform .4s;
  }
  .gallery-featured img {
    height: 100%;
    min-height: 580px;
  }
  .gallery-item:hover img { transform: scale(1.04); }

  .gallery-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 14px 16px;
    background: linear-gradient(transparent, rgba(2,2,2,.9));
    font-family: var(--mono);
    font-size: 9px;
    color: var(--ow);
    letter-spacing: .08em;
    text-transform: uppercase;
    transform: translateY(4px);
    opacity: .7;
    transition: transform .3s, opacity .3s;
  }
  .gallery-item:hover .gallery-label {
    transform: translateY(0);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-featured { grid-column: span 2; grid-row: span 1; }
    .gallery-featured img { min-height: 280px; }
    .gallery-item img { height: 200px; }
  }

  @media (max-width: 480px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-featured { grid-column: span 1; }
  }
</style>
