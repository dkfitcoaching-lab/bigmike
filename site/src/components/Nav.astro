---
const bookingUrl = 'https://big-mike-108395.square.site/';
---

<nav class="site-nav" id="siteNav">
  <div class="nav-logo">
    <div class="nav-logo-mark"><span>M</span></div>
    <div class="nav-logo-text">Big Mike Ely</div>
  </div>
  <div class="nav-links">
    <a href="#services">Services</a>
    <a href="#about">About</a>
    <a href="#results">Results</a>
    <a href="#gallery">Gallery</a>
    <a href={bookingUrl} target="_blank" rel="noopener" class="nav-cta">Book a Session</a>
  </div>
  <button class="nav-menu-btn" id="navMenuBtn" aria-label="Open menu">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
  </button>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  <a href={bookingUrl} target="_blank" rel="noopener" class="mm-cta">Book a Session</a>
  <div class="mm-divider"></div>
  <a href="#services" class="mm-link">Services</a>
  <a href="#about" class="mm-link">About</a>
  <a href="#results" class="mm-link">Results</a>
  <a href="#gallery" class="mm-link">Gallery</a>
  <div class="mm-badge">IFBB Pro Big Mike Ely</div>
  <button class="mm-close" id="mmClose" aria-label="Close menu">&times;</button>
</div>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(2,2,2,.85);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid transparent;
    transition: border-color .3s;
  }
  .site-nav.scrolled { border-bottom-color: var(--borderS); }

  .nav-logo { display: flex; align-items: center; gap: 12px; }
  .nav-logo-mark {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: linear-gradient(145deg, #0c0c0c, #060606);
    border: 1.5px solid var(--accB);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--display);
    font-size: 20px;
    font-weight: 900;
    box-shadow: 0 0 8px var(--accGlow);
  }
  .nav-logo-mark span {
    background: var(--goldGrad);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .nav-logo-text {
    font-family: var(--display);
    font-size: 14px;
    font-weight: 700;
    color: var(--ice);
    letter-spacing: .04em;
  }

  .nav-links { display: flex; gap: 28px; align-items: center; }
  .nav-links a {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .14em;
    color: var(--dm);
    text-transform: uppercase;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--acc); }

  .nav-cta {
    background: var(--goldGrad);
    background-size: 200% 100%;
    color: var(--bg) !important;
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .12em;
    padding: 10px 20px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    animation: shimmer 3s ease-in-out infinite;
    text-decoration: none;
    display: inline-block;
  }

  .nav-menu-btn {
    display: none;
    background: none;
    border: none;
    color: var(--dm);
    cursor: pointer;
    padding: 8px;
  }

  /* Mobile Menu */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(2,2,2,.99);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 80px 40px;
  }
  .mobile-menu.open { display: flex; }

  .mm-cta {
    display: block;
    background: var(--goldGrad);
    background-size: 200% 100%;
    color: var(--bg);
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .14em;
    padding: 18px 48px;
    border-radius: 12px;
    text-transform: uppercase;
    text-decoration: none;
    animation: shimmer 3s ease-in-out infinite;
    box-shadow: 0 4px 24px var(--accM);
    margin-bottom: 48px;
    min-width: 240px;
    text-align: center;
  }

  .mm-divider {
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accDeep), var(--acc), var(--accDeep), transparent);
    margin-bottom: 40px;
  }

  .mm-link {
    display: block;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--dm);
    letter-spacing: .2em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 0;
    transition: color .2s;
    border-bottom: 1px solid rgba(255,255,255,.04);
  }
  .mm-link:last-of-type { border-bottom: none; }
  .mm-link:hover, .mm-link:active { color: var(--acc); }

  .mm-close {
    position: absolute;
    top: 20px;
    right: 24px;
    background: none;
    border: 1px solid var(--borderS);
    border-radius: 10px;
    color: var(--dm);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 20px;
    transition: border-color .2s;
  }
  .mm-close:hover { border-color: var(--acc); color: var(--acc); }

  .mm-badge {
    font-family: var(--mono);
    font-size: 8px;
    color: var(--dmL);
    letter-spacing: .2em;
    text-transform: uppercase;
    margin-top: 48px;
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-menu-btn { display: block; }
    .site-nav {
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
  }
</style>

<script>
  const nav = document.getElementById('siteNav');
  const menu = document.getElementById('mobileMenu');
  const menuBtn = document.getElementById('navMenuBtn');
  const closeBtn = document.getElementById('mmClose');

  function toggleMenu() {
    menu?.classList.toggle('open');
  }

  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 50);
  });

  menuBtn?.addEventListener('click', toggleMenu);
  closeBtn?.addEventListener('click', toggleMenu);

  menu?.querySelectorAll('.mm-link').forEach(link => {
    link.addEventListener('click', toggleMenu);
  });

  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', (e) => {
      const target = document.querySelector(a.getAttribute('href')!);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
