---
const bookingUrl = 'https://big-mike-108395.square.site/';
---

<section class="hero">
  <div class="hero-vignette"></div>
  <div class="hero-content">
    <div class="hero-badge">
      <div class="hero-badge-line"></div>
      <span class="hero-badge-text">IFBB PRO</span>
      <div class="hero-badge-line" style="transform:rotate(180deg)"></div>
    </div>
    <h1>Big <em>Mike</em> Ely</h1>
    <div class="hero-subtitle">World Champion</div>
    <div class="hero-ctas">
      <a href={bookingUrl} target="_blank" rel="noopener" class="btn-primary">BOOK A SESSION</a>
      <a href="#services" class="btn-secondary">VIEW SERVICES</a>
    </div>
  </div>
  <div class="hero-scroll">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 120px 24px 80px;
    background:
      linear-gradient(to bottom, rgba(2,2,2,.55) 0%, rgba(2,2,2,.7) 50%, var(--bg) 100%),
      url('/img/hero-stage-2025.jpg') center 15% / cover no-repeat;
    background-attachment: scroll, fixed;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 50%, transparent 40%, var(--bg) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 700px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
  }
  .hero-badge-line {
    width: 40px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accB));
  }
  .hero-badge-text {
    font-family: var(--mono);
    font-size: clamp(9px, 2vw, 11px);
    font-weight: 700;
    letter-spacing: clamp(.15em, 1.5vw, .4em);
    background: var(--goldGrad);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s ease-in-out infinite;
  }

  h1 {
    font-family: var(--display);
    font-size: clamp(36px, 8vw, 64px);
    font-weight: 800;
    color: var(--ice);
    letter-spacing: .06em;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  h1 em {
    font-style: normal;
    background: var(--goldGrad);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s ease-in-out infinite;
  }

  .hero-subtitle {
    font-family: var(--mono);
    font-size: clamp(10px, 2vw, 13px);
    font-weight: 700;
    letter-spacing: clamp(.2em, 2vw, .5em);
    color: var(--dm);
    text-transform: uppercase;
    margin-bottom: 36px;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--goldGrad);
    background-size: 200% 100%;
    color: var(--bg);
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .12em;
    padding: 18px 36px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    box-shadow: 0 4px 24px var(--accM);
    animation: shimmer 3s ease-in-out infinite;
    text-decoration: none;
    min-height: 50px;
    display: inline-flex;
    align-items: center;
  }
  .btn-secondary {
    background: var(--accS);
    color: var(--acc);
    border: 1.5px solid var(--borderH);
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .1em;
    padding: 18px 36px;
    border-radius: 12px;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: all .2s;
  }
  .btn-secondary:hover {
    background: var(--accGlow);
    border-color: var(--acc);
  }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--dm);
    font-family: var(--mono);
    font-size: 8px;
    letter-spacing: .2em;
    text-transform: uppercase;
    animation: scrollBounce 2s ease-in-out infinite;
  }
  .hero-scroll svg { opacity: .5; }

  @media (max-width: 768px) {
    .hero {
      padding: 100px 20px 80px;
      min-height: 90vh;
      background-attachment: scroll, scroll;
    }
  }
</style>
