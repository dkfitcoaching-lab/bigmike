---
const bookingUrl = 'https://big-mike-108395.square.site/';
---

<section class="section-pad cta-section">
  <div class="cta-inner">
    <div class="section-title">Book a Session</div>
    <a href={bookingUrl} target="_blank" rel="noopener" class="btn-primary">BOOK YOUR SESSION</a>
  </div>
</section>

<style>
  .cta-section {
    background:
      linear-gradient(160deg, rgba(2,2,2,.92), rgba(2,2,2,.88)),
      url('/img/about-back-gym.jpg') center / cover no-repeat;
    border-top: 1px solid var(--borderS);
    border-bottom: 1px solid var(--borderS);
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accS), transparent 60%);
    transform: translate(-50%, -50%);
    filter: blur(80px);
    pointer-events: none;
  }

  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .btn-primary {
    background: var(--goldGrad);
    background-size: 200% 100%;
    color: var(--bg);
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .12em;
    padding: 20px 48px;
    border-radius: 14px;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    box-shadow: 0 4px 24px var(--accM);
    animation: shimmer 3s ease-in-out infinite;
    text-decoration: none;
    display: inline-block;
    min-height: 54px;
  }
</style>
