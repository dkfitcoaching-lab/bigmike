---
const bookingUrl = 'https://big-mike-108395.square.site/';
---

<footer class="site-footer">
  <div class="footer-logo"><span>M</span></div>
  <div class="footer-links">
    <a href="#services">Services</a>
    <a href="#about">About</a>
    <a href="#results">Results</a>
    <a href="#gallery">Gallery</a>
    <a href={bookingUrl} target="_blank" rel="noopener">Book</a>
    <a href="/app.html" style="opacity:.4">Coach Login</a>
  </div>
  <div class="footer-social">
    <a href="https://instagram.com/ifbbpromikeely" target="_blank" rel="noopener" aria-label="Instagram">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="2" y="2" width="20" height="20" rx="5"/>
        <circle cx="12" cy="12" r="5"/>
        <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>
      </svg>
    </a>
    <a href="https://instagram.com/center_stage_aesthetics" target="_blank" rel="noopener" aria-label="Center Stage Aesthetics">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/>
      </svg>
    </a>
    <a href="https://facebook.com/BIGMIKEELY" target="_blank" rel="noopener" aria-label="Facebook">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
      </svg>
    </a>
  </div>
  <div class="gw" style="max-width:200px;margin:0 auto 20px"></div>
  <div data-wc="footer-tagline" style="display:none;font-size:11px;color:var(--dm);font-family:var(--mono);letter-spacing:.06em;margin-bottom:12px"></div>
  <div class="footer-copy">&copy; 2026 Big Mike Ely Coaching. All rights reserved.</div>
  <a href="https://vermillionaxis.tech" target="_blank" rel="noopener" class="vat-badge">
    <svg width="28" height="34" viewBox="0 0 28 34" fill="none">
      <path d="M14 1 C6 1 2 6 2 12 L2 26 C2 26 2 26 2 26" stroke="rgba(58,52,40,.5)" stroke-width=".8" fill="none"/>
      <path d="M14 1 C22 1 26 6 26 12 L26 26 C26 26 26 26 26 26" stroke="rgba(58,52,40,.5)" stroke-width=".8" fill="none"/>
      <path d="M2 26 L26 26" stroke="rgba(58,52,40,.3)" stroke-width=".8"/>
      <line x1="8" y1="10" x2="14" y2="22" stroke="rgba(58,52,40,.6)" stroke-width="1"/>
      <line x1="20" y1="10" x2="14" y2="22" stroke="rgba(58,52,40,.6)" stroke-width="1"/>
      <circle cx="14" cy="7" r="1.5" fill="rgba(180,60,60,.4)"/>
      <circle cx="14" cy="23" r="1.5" fill="rgba(180,60,60,.3)"/>
    </svg>
    <span>VERMILLION<br/>AXIS<br/>TECHNOLOGIES</span>
  </a>
</footer>

<style>
  .site-footer {
    padding: 60px 24px 40px;
    text-align: center;
  }

  .footer-logo {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: linear-gradient(145deg, #0c0c0c, #060606);
    border: 1.5px solid var(--borderS);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--display);
    font-size: 28px;
    font-weight: 900;
    margin-bottom: 20px;
  }
  .footer-logo span {
    background: var(--goldGrad);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .footer-links a {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .1em;
    color: var(--dm);
    text-transform: uppercase;
    transition: color .2s;
  }
  .footer-links a:hover { color: var(--acc); }

  .footer-social {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 24px;
  }
  .footer-social a {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: var(--glassB);
    border: 1px solid var(--borderS);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--dm);
    transition: all .2s;
  }
  .footer-social a:hover {
    border-color: var(--accB);
    color: var(--acc);
  }

  .footer-copy {
    font-size: 10px;
    color: var(--dmL);
    font-family: var(--mono);
    letter-spacing: .06em;
  }

  .vat-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 12px;
    text-decoration: none;
    transition: opacity .2s;
    opacity: .45;
  }
  .vat-badge:hover { opacity: .7; }
  .vat-badge svg { flex-shrink: 0; }
  .vat-badge span {
    font-size: 8px;
    color: var(--dmL);
    font-family: var(--mono);
    letter-spacing: .14em;
    line-height: 1.5;
  }
</style>
